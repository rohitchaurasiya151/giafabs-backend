# Copy this file to .env.development / .env.staging / .env.production and
# fill in real values. Only this file (.env.example) is committed to git —
# see README.md "Environment Configuration" for how each environment loads
# its config and which of these are required per environment.

# ── App / Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# Frontend origin allowed to call this API. "*" is fine for local dev only.
CORS_ORIGIN=*

# ── Database ──────────────────────────────────────────────────────────────
# If DATABASE_URL is set, it takes precedence over the discrete PG* vars
# below (this is how most hosting platforms — Render, Railway, etc. —
# inject a managed Postgres connection string).
# DATABASE_URL=postgres://user:password@host:5432/dbname
PGHOST=localhost
PGPORT=8090
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=giafabs_db

# ── Auth ──────────────────────────────────────────────────────────────────
# Required in staging/production (min 16 chars) — no default is allowed there.
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRE=7d

# ── External APIs: Cloudinary (image storage) ───────────────────────────
# Required in staging/production.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── External APIs: Razorpay (payments) ──────────────────────────────────
# Required in staging/production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Storage: uploads & image processing ─────────────────────────────────
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
MAX_FILE_SIZE=5242880
MAX_FILES_PER_PRODUCT=10
MIN_IMAGE_WIDTH=300
MIN_IMAGE_HEIGHT=300
THUMBNAIL_WIDTH=150
THUMBNAIL_HEIGHT=150
MOBILE_WIDTH=600

# ── Logging ───────────────────────────────────────────────────────────────
# Optional override. Without it: debug in development, info in staging,
# error in production.
# LOG_LEVEL=debug

# ── Feature Flags ─────────────────────────────────────────────────────────
ENABLE_CACHE=false
ENABLE_ANALYTICS=false
ENABLE_NEW_UI=false

# ── Admin bootstrap ───────────────────────────────────────────────────────
# Required in staging/production (min 8 chars) — used to seed the first
# superadmin user on a fresh database.
ADMIN_EMAIL=admin@giafabs.com
ADMIN_INITIAL_PASSWORD=change-me-on-first-login
