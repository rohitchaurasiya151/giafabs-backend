# Database Configuration
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=giafabs_db
PGPOOL_MAX=20

# Server Configuration
NODE_ENV=development
PORT=3000

# Redis Cache
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=24h

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@giafabs.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# File Upload & Image Processing
UPLOAD_ENABLED=true
MAX_FILE_SIZE=5242880
MAX_FILES_PER_PRODUCT=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
MIN_IMAGE_WIDTH=300
MIN_IMAGE_HEIGHT=300

# Image Processing (Cloudinary eager transform dimensions)
THUMBNAIL_WIDTH=150
THUMBNAIL_HEIGHT=150
MOBILE_WIDTH=600

# Storage Backend: Cloudinary (get credentials from cloudinary.com dashboard)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Payment Gateway (Phase 3.3)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Admin Configuration
ADMIN_EMAIL=admin@giafabs.com
ADMIN_INITIAL_PASSWORD=change-me-on-first-login

# Inventory Settings
REORDER_LEVEL=10
STOCK_RESERVATION_MINUTES=30
LOW_STOCK_ALERT=true

# API Documentation
SWAGGER_ENABLED=true

# Monitoring & Analytics (Optional)
SENTRY_DSN=
DATADOG_API_KEY=

# Feature Flags
ENABLE_B2B_PRICING=true
ENABLE_GST_CALCULATION=true
ENABLE_INVENTORY_TRACKING=true
