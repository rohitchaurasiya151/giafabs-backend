{
  "name": "giafabs-backend",
  "version": "1.0.0",
  "description": "GIAFABS Enterprise Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env NODE_ENV=development node --watch server.js",
    "staging": "cross-env NODE_ENV=staging node server.js",
    "production": "cross-env NODE_ENV=production node server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest src/__tests__ --testPathPattern='(?!integration|load-test)'",
    "test:integration": "jest --testPathPattern=integration",
    "load-test": "node src/__tests__/load-test.js",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "file-type": "^22.0.1",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "razorpay": "^2.9.6",
    "sharp": "^0.35.3",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "private": true
}
